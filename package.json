{
  "name": "release-health-monorepo",
  "private": true,
  "description": "Monorepo for react-native-release-health and its adapters and sinks",
  "workspaces": [
    "packages/*",
    "example",
    "example-hot-updater",
    "scripts/hot-updater-server"
  ],
  "scripts": {
    "example": "yarn workspace react-native-release-health-example",
    "example-hot-updater": "yarn workspace release-health-example-hot-updater",
    "core": "yarn workspace react-native-release-health",
    "sink-http": "yarn workspace @release-health/sink-http",
    "adapter-expo-updates": "yarn workspace @release-health/adapter-expo-updates",
    "adapter-hot-updater": "yarn workspace @release-health/adapter-hot-updater",
    "sink-sentry": "yarn workspace @release-health/sink-sentry",
    "hot-updater-server": "yarn workspace release-health-hot-updater-demo-server start",
    "typecheck": "yarn workspaces foreach -A --exclude release-health-monorepo run typecheck",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "yarn workspaces foreach -A --exclude release-health-monorepo run test",
    "build": "yarn workspaces foreach -A --topological-dev --exclude release-health-monorepo run prepare",
    "clean": "yarn workspaces foreach -A --exclude release-health-monorepo run clean",
    "receiver": "node scripts/event-receiver.mjs",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.11.0",
  "engines": {
    "node": ">=20"
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
