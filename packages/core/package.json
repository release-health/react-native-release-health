{
  "name": "react-native-release-health",
  "version": "0.0.2",
  "description": "Vendor-neutral OTA rollout health for React Native: session tagging, failed-update detection, and rollback recommendations.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-release-health-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "ota",
    "expo-updates",
    "hot-updater",
    "release-health",
    "rollback",
    "crash-loop"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/release-health/react-native-release-health.git"
  },
  "author": "Amrith Vengalath <amrith@vengalath.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/release-health/react-native-release-health/issues"
  },
  "homepage": "https://github.com/release-health/react-native-release-health#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "jest": "^29.7.0",
    "react": "19.2.0",
    "react-native": "0.83.10",
    "react-native-builder-bob": "^0.43.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "ReleaseHealthSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.releasehealth"
    }
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "require",
        "react-native",
        "react-native-release-health-source"
      ]
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "jest"
    ],
    "version": "0.63.0"
  }
}
